# --- Database ---
DATABASE_URL="postgresql://appable:appable@localhost:5432/appable"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- Auth ---
JWT_SECRET="change-me-in-production"

# --- DeepInfra (OpenAI-compatible) ---
# NOTE: rotate your key before going live; never commit the real .env
DEEPINFRA_API_KEY="your-deepinfra-key-here"
DEEPINFRA_BASE_URL="https://api.deepinfra.com/v1/openai"

# --- Fireworks (OpenAI-compatible) - optional, used for edits (faster) ---
# Leave empty to run edits on the DeepInfra build model instead.
FIREWORKS_API_KEY=""
FIREWORKS_BASE_URL="https://api.fireworks.ai/inference/v1"

# Model routing
MODEL_BUILD="moonshotai/Kimi-K2.6"
MODEL_CHAT="Qwen/Qwen3.6-35B-A3B"
MODEL_EDIT="accounts/fireworks/models/kimi-k2p6"

# --- Services ---
API_PORT=4000
PROXY_PORT=4100
WEB_PORT=5173

# Public host used in preview/QR URLs. "auto" detects your LAN IP so a
# phone on the same Wi-Fi can reach Metro. Set an explicit IP/domain to
# override (e.g. 192.168.1.50 or your production domain).
PUBLIC_HOST="auto"

# --- Containers ---
GOLDEN_IMAGE="appable/expo-template:latest"
# Where project files live on the host (mounted into containers)
PROJECTS_DIR="./data/projects"
# Containers sleep after this many minutes without activity
IDLE_TIMEOUT_MINUTES=15
