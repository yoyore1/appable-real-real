generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  projects     Project[]
}

model Project {
  id            String         @id @default(cuid())
  name          String
  status        String         @default("new") // ProjectStatus in @appable/shared
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  containerId   String?
  /// When the $1 build fee was paid (null = not yet paid)
  paidAt        DateTime?
  /// Host port mapped to Expo web inside the container
  webPort       Int?
  /// Host port mapped to Metro (Expo Go bundle) inside the container
  metroPort     Int?
  lastActiveAt  DateTime       @default(now())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  specs         Spec[]
  conversations Conversation[]
  checkpoints   Checkpoint[]
  buildEvents   BuildEvent[]
}

model Spec {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  version   Int
  /// AppSpec JSON from @appable/shared
  data      Json
  createdAt DateTime @default(now())

  @@unique([projectId, version])
}

model Conversation {
  id        String    @id @default(cuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id])
  kind      String // "interview" | "brainstorm" | "build"
  createdAt DateTime  @default(now())
  messages  Message[]

  @@unique([projectId, kind])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  role           String // "user" | "assistant" | "system" | "tool"
  content        String
  /// Model that produced this message, if assistant
  model          String?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

model Checkpoint {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  /// Git commit hash inside the project volume
  gitRef    String
  label     String
  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
}

model BuildEvent {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  level     String // "info" | "warn" | "error"
  source    String // "agent" | "metro" | "system"
  text      String
  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
}
